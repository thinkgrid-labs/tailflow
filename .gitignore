# Build output
/target

# Cargo.lock should be committed for binaries (tailflow, tailflow-daemon)
# Remove this line if you want reproducible builds pinned
# Cargo.lock

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes

# Editor directories and files
.idea/
.vscode/
*.sw?
*.swp
*~

# Environment / secrets
.env
.env.*
!.env.example

# Test log files generated during development
*.log

# Node / web UI
node_modules/
# Keep web/dist/.gitkeep but ignore build artifacts
web/dist/assets/
web/dist/*.html
web/dist/*.js
web/dist/*.css

# Compiled binaries staged for npm publishing (added by scripts/pack-local.sh
# and the release CI — never committed)
npm/platforms/*/bin/tailflow
npm/platforms/*/bin/tailflow-daemon
npm/platforms/*/bin/tailflow.exe
npm/platforms/*/bin/tailflow-daemon.exe
npm/platforms/*/*.tgz
npm/tailflow/*.tgz
